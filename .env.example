# ----------------------------------------------------------------------------
# Personal Finance Assistant — environment variables
# Copy this file to `.env` and fill in the values.
# ----------------------------------------------------------------------------

# Database (SQLite by default; swap for a Postgres URL to scale)
DATABASE_URL="file:./dev.db"

# Google Gemini API key — get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# Clerk authentication — keys from https://dashboard.clerk.com
# If these are left blank, the app falls back to a single-user DEV mode
# (no sign-in required) so it can be run instantly without a Clerk account.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# Clerk redirect URLs (defaults are fine for local dev)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
